    </mxCell>

    <!-- finalize → payment -->
    <mxCell id="e_final_pay" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="finalize" target="payment" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- CONNECTIONS — LANE 3 (PRIVATE INVOICE / USB PATH) -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <!-- inv_type → USB gate (right) -->
    <mxCell id="e_invtype_usb" value="Non-GST / Private" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#7b00d4;fontColor=#7b00d4;fontStyle=1;" edge="1" source="inv_type" target="usb_gate" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- usb_gate → usb_auth_box (not authorized) -->
    <mxCell id="e_usb_notauth" value="Not Authorized" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#b85450;fontColor=#b85450;" edge="1" source="usb_gate" target="usb_auth_box" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- usb_auth_box loops back to usb_gate (retry) -->
    <mxCell id="e_auth_retry" value="Retry" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#7b00d4;curved=1;dashed=1;" edge="1" source="usb_auth_box" target="usb_gate" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- usb_gate → private invoice (authorized) -->
    <mxCell id="e_usb_priv" value="Authorized ✓" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#7b00d4;fontColor=#7b00d4;fontStyle=1;" edge="1" source="usb_gate" target="priv_inv" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- usb_gate → denied -->
    <mxCell id="e_usb_denied" value="Refused" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#b85450;fontColor=#b85450;" edge="1" source="usb_gate" target="usb_denied" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- priv_inv → priv_admin -->
    <mxCell id="e_priv_admin" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#4a0070;dashed=1;" edge="1" source="priv_inv" target="priv_admin" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- priv_inv → payment (also generates receivable) -->
    <mxCell id="e_priv_pay" value="Cash Collected" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#7b00d4;dashed=1;" edge="1" source="priv_inv" target="payment" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- CONNECTIONS — LANE 4 (PAYMENT) -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <mxCell id="e_pay_link" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="payment" target="pay_link" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>
    <mxCell id="e_link_status" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="pay_link" target="pay_status" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>
    <mxCell id="e_status_ledger" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="pay_status" target="ledger" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>
    <mxCell id="e_ledger_outstanding" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="ledger" target="outstanding" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- CONNECTIONS — LANE 4→5 (PAYMENT to SYNC) -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <mxCell id="e_pay_tally" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="payment" target="tally" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>
    <mxCell id="e_finalize_tally" value="Auto / Manual Sync" style="edgeStyle=orthogonalEdgeStyle;dashed=1;" edge="1" source="finalize" target="tally" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- CONNECTIONS — LANE 5 (REPORTS) -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <mxCell id="e_tally_gst" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="tally" target="gst_reports" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>
    <mxCell id="e_gst_weight" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="gst_reports" target="weight_reg" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>
    <mxCell id="e_weight_pl" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="weight_reg" target="pl" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>
    <mxCell id="e_pl_dash" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="pl" target="dashboard" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>
    <mxCell id="e_dash_backup" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="dashboard" target="backup" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>
    <mxCell id="e_backup_end" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="backup" target="end" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- USB DETAIL BOX (Callout) -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <mxCell id="usb_detail" value="USB PENDRIVE FLOW DETAIL&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;1. Admin inserts USB → runs setup_usb_key.py&#xa;   → UUID written to .weighbridge_key on USB&#xa;   → UUID registered in usb_keys DB table&#xa;&#xa;2. Operator inserts USB at workstation&#xa;   → App auto-scans drive letters (A-Z)&#xa;   → Finds .weighbridge_key → verifies UUID&#xa;   → Server USB session = authorized&#xa;&#xa;3. Remote Client (LAN)&#xa;   → Click 'Authenticate with USB'&#xa;   → Browser file picker → select key file&#xa;   → UUID sent to /api/v1/usb-guard/client-auth&#xa;   → 8-hour session created&#xa;&#xa;4. Recovery (no USB available)&#xa;   → Admin pre-creates PIN + expiry hours&#xa;   → Operator enters PIN at lock screen&#xa;   → Time-limited recovery session granted&#xa;&#xa;5. What USB unlocks:&#xa;   → Non-GST / Private Invoice creation&#xa;   → /private-invoices page access&#xa;   → Option appears in New Invoice dialog" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0e6ff;strokeColor=#7b00d4;align=left;fontSize=9;fontFamily=Courier New;" vertex="1" parent="1">
      <mxGeometry x="80" y="830" width="440" height="320" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- TEST SCENARIOS TABLE -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <mxCell id="test_table" value="E2E TEST SCENARIOS&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;#  Scenario                          Expected Result&#xa;1  Create Customer Party              Saved, appears in dropdown&#xa;2  Create Product (Gitti 20mm)        HSN+GST rate saved&#xa;3  Token: 2-stage weighment           Net = Gross - Tare, COMPLETED&#xa;4  Create &amp; Finalise Sale Invoice     Invoice No generated, PDF ready&#xa;5  Record Partial Payment             Status: Partial, balance shown&#xa;6  Full Payment Settlement            Status: Paid, zero outstanding&#xa;7  Create Purchase Invoice (GST)      CGST+SGST calculated correctly&#xa;8  Tally Sync — single invoice        Green checkmark ✓, tally_synced=true&#xa;9  GSTR-1 CSV Export                  B2B + B2C + HSN rows correct&#xa;10 USB Insert → Private Invoice       PRIV/0001 created, hidden from GST UI&#xa;11 USB Remove → Private blocked       403 / lock screen shown&#xa;12 Recovery PIN — time-limited        Access granted for N hours only&#xa;13 priv-admin view                    All private invoices visible (no USB)&#xa;14 Dashboard Charts load              5 charts, real data, no JS errors&#xa;15 Backup → Restore                   pg_dump created, restored cleanly" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;align=left;fontSize=9;fontFamily=Courier New;" vertex="1" parent="1">
      <mxGeometry x="550" y="830" width="560" height="320" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- INDUSTRY GAP ANALYSIS -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <mxCell id="gaps" value="INDUSTRY GAP ANALYSIS (vs BUSY / Marg ERP / Tally Add-ons)&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;Priority  Feature                     Impact&#xa;HIGH      Royalty Management          Govt royalty/MT auto-deduction&#xa;HIGH      E-Way Bill Integration      NIC API for invoices &gt; ₹50,000&#xa;HIGH      Despatch Register (FORM-1)  Mines Act statutory register&#xa;HIGH      Rate Contract Management    Validity alerts, auto-apply&#xa;HIGH      Lab Quality Reports         Sieve analysis attached to token&#xa;MEDIUM    RFID / Vehicle Tracking     Auto-identify truck at gate&#xa;MEDIUM    Camera Integration          Photo linked to token record&#xa;MEDIUM    Overloading Alerts          Alert if net weight &gt; rated cap&#xa;MEDIUM    Mobile App / PWA            Supervisor approvals on phone&#xa;LOW       Bank Reconciliation         Import bank CSV → auto-match" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff9e6;strokeColor=#d6a800;align=left;fontSize=9;fontFamily=Courier New;" vertex="1" parent="1">
      <mxGeometry x="1130" y="830" width="500" height="320" as="geometry" />
    </mxCell>

  </root>
</mxGraphModel>
