# ============================================================================
# Weighbridge ERP — Environment Variables Template
# ============================================================================
# Copy this file to .env and fill in real values:
#   copy .env.example .env
#
# NEVER commit .env to git — it contains secrets.
# The Install-Client.ps1 script auto-generates .env with random secrets.
# ============================================================================

# ── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection strings (async + sync drivers)
# Change password to a strong random value in production
DATABASE_URL=postgresql+asyncpg://weighbridge:CHANGE_ME@localhost:5432/weighbridge
DATABASE_URL_SYNC=postgresql+psycopg://weighbridge:CHANGE_ME@localhost:5432/weighbridge

# ── Authentication ──────────────────────────────────────────────────────────
# JWT signing key — use a random 64-character hex string
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_TO_RANDOM_64_HEX_CHARS

# JWT algorithm (do not change)
ALGORITHM=HS256

# Session duration in minutes (480 = 8 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Encryption ──────────────────────────────────────────────────────────────
# AES-256 key for private invoice encryption (64-character hex string)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
PRIVATE_DATA_KEY=CHANGE_ME_TO_RANDOM_64_HEX_CHARS

# ── Company (optional defaults) ─────────────────────────────────────────────
COMPANY_NAME=Stone Crusher Enterprises

# ── Serial Port (weight scale — configure via Settings UI) ──────────────────
# SERIAL_PORT=COM1
# SERIAL_BAUD_RATE=9600
# SERIAL_PROTOCOL=generic
